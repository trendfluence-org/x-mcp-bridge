# Twitter Bridge MCP — Configuration
# Copy this file to .env and fill in your values

# Public URL (your Cloudflare Tunnel or reverse proxy URL)
BASE_URL=https://your-domain.example.com

# Server port
PORT=8080

# Chrome DevTools Protocol port (must match Chrome's --remote-debugging-port)
CDP_PORT=9222

# Path to bb-browser binary
BB_BROWSER_PATH=/usr/local/bin/bb-browser

# OAuth credentials (change these!)
OAUTH_CLIENT_ID=twitter-mcp-client
OAUTH_CLIENT_SECRET=change-me-to-something-random

# Twitter DM encryption PIN (optional, leave empty if not set up)
DM_PIN=
