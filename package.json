{
  "name": "x-mcp-bridge",
  "version": "0.1.8",
  "description": "Connect Claude to Twitter/X via Playwright browser automation — no API key needed",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "x-mcp-bridge": "server.mjs"
  },
  "files": [
    "server.mjs",
    "run.sh",
    "assets/"
  ],
  "scripts": {
    "start": "node server.mjs",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "playwright": "^1.52.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.24.3"
  },
  "keywords": [
    "mcp",
    "twitter",
    "x",
    "claude",
    "browser-automation",
    "playwright"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
